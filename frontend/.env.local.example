# Supabase — API Settings in dashboard
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
# Legacy anon key (eyJ...) or new publishable key (sb_publishable_...)
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...

# Backend API URL
# Local dev: http://localhost:3001
# Netlify production: leave empty (uses same-origin /api/* functions)
NEXT_PUBLIC_API_URL=http://localhost:3001

# Firebase client auth — Project settings > General > Web app config
NEXT_PUBLIC_FIREBASE_API_KEY=...
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_APP_ID=...
