# Database
DATABASE_URL=postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres

# Supabase
SUPABASE_URL=https://xxxx.supabase.co
# Legacy JWT key (eyJ...) or new secret key (sb_secret_...)
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...
# Optional — used by some JWT verification setups
# SUPABASE_JWKS_URL=https://xxxx.supabase.co/auth/v1/.well-known/jwks.json

# Firebase Admin SDK — full service account JSON (minified, single line)
# Get it: Firebase Console → Project Settings → Service Accounts → Generate new key
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"...","universe_domain":"googleapis.com"}

# ── Snwolley ────────────────────────────────────────────────────────────────
# Team key  → used for STT, TTS, Vision  (X-API-Key header)
SNWOLLEY_HACKATHON_API_KEY=hk_team0X_...

# Platform key → used for Agents / Chat (X-APIKey header)
# Get it: v1.snwolley.ai → profile → My Organization → API Settings
SNWOLLEY_AGENT_API_KEY=your_platform_key_here

# Agent ID to use (default 107 — check with organizers for your assigned ID)
SNWOLLEY_AGENT_ID=107

# AI provider for chat: "gemini" | "snwolley" | "openai"
AI_PROVIDER=gemini

# ── Gemini (used when AI_PROVIDER=gemini) ──────────────────────────────────
# Get a key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-2.5-flash

# ── OpenAI (optional — only needed when AI_PROVIDER=openai) ─────────────────
# OPENAI_API_KEY=sk-...

# Docling microservice
DOCLING_SERVICE_URL=http://localhost:8001

# Redis — Upstash (BullMQ + general cache)
# Use the rediss:// URL for ioredis/BullMQ (TLS required by Upstash)
REDIS_URL=rediss://default:<token>@<host>.upstash.io:6379
# REST credentials for @upstash/redis or direct HTTP usage
UPSTASH_REDIS_REST_URL=https://<host>.upstash.io
UPSTASH_REDIS_REST_TOKEN=<token>

# CORS
FRONTEND_URL=http://localhost:3000

# Server
PORT=3001

# Rate limiting (optional — defaults shown)
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_READ_MAX=600
# RATE_LIMIT_WRITE_MAX=80
# Set RATE_LIMIT=true in development to test rate limiting locally
# TRUST_PROXY=true
